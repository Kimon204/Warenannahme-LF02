# Kopiere diese Datei nach .env und trage deine Werte ein.

# Mock-Modus: true = kein Backend nötig | false = Supabase
VITE_USE_MOCK=true

# Supabase-Zugangsdaten (nur nötig wenn VITE_USE_MOCK=false)
# Zu finden unter: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
